# --- Python Core ---
__pycache__/
*.py[cod]
*$py.class

# --- Security & Environment (CRITICAL) ---
.env
.env.*
!.env.example
venv/
env/
.venv/
.conda/

# --- Distribution / Build (generated by pip install -e .) ---
build/
dist/
*.egg-info/
.eggs/
src/*.egg-info/

# --- IDEs & OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Jupyter Notebooks ---
.ipynb_checkpoints
*-checkpoint.ipynb
# Optional: Ignore execution outputs in notebooks if you want clean history
# *.nbconvert.ipynb

# --- Logs ---
*.log
logs/

# --- Data Pipeline ---
# We ignore the files but keep the folder structure
data/raw/*
data/processed/*
data/ground_truth/*
data/results/*
data/artifacts/*
data/splits.json

# Exceptions: Keep .gitkeep to preserve directory structure in Git
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/ground_truth/.gitkeep
!data/results/.gitkeep
!data/artifacts/.gitkeep

# --- ML & Library Caches ---
dspy_cache/
.cache/
__pycache__/