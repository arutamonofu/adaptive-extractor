# .env.example
# Copy this file to .env and fill in your actual values

# Environment (dev, test, prod)
AEE_ENV=dev

# Ollama URLs (REQUIRED if use_ollama: true in YAML config)
OLLAMA_STUDENT_BASE_URL=http://localhost:11434
OLLAMA_TEACHER_BASE_URL=http://localhost:11434

# LLM API Keys (REQUIRED if use_ollama: false in YAML config)
# System automatically selects key based on base_url or model name prefix
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# HUGGINGFACE_API_KEY=your_huggingface_key_here

# Infrastructure
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
DSPY_CACHE_DIR=${HOME}/.dspy_cache